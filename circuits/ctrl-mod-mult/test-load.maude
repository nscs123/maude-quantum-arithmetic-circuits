red loadX(0, 1 2, 3 4) x vect(0)(x) vect(1 1) (x) vect(0 0) == vect(0)(x) vect(1 1) (x) vect(0 0) .


red loadN(0 1, 1 1) x vect(0 0) == vect(1 1) .
red loadN(0 1, 1 0) x vect(0 0) == vect(1 0) .
red loadN(0 1, 0 1) x vect(0 0) == vect(0 1) .
red loadN(0 1, 0 0) x vect(0 0) == vect(0 0) .