load ./ctrl-mod-mult.maude
load ../../common/vect.maude


fmod TEST_LOAD is
    pr CTRL-MOD-MULT .
    pr VECT .
    pr NAT .


    op load-unload : Nat BitList -> Mat .

    var N : Nat .
    var BL : BitList .

    eq [load-unload] : load-unload(N, BL) = unload(0, 1, nList(2,N + 1), BL) x load(0, 1, nList(2,N + 1), BL) .
endfm

red load(0, 1, 2 3, 0 0) x vect(0 0) (x) vect(0 0) == vect(0 0) (x) vect(0 0) .
red load(0, 1, 2 3, 0 1) x vect(0 0) (x) vect(0 0) == vect(0 0) (x) vect(0 0) .
red load(0, 1, 2 3, 1 0) x vect(0 0) (x) vect(0 0) == vect(0 0) (x) vect(0 0) .
red load(0, 1, 2 3, 1 1) x vect(0 0) (x) vect(0 0) == vect(0 0) (x) vect(0 0) .

red load(0, 1, 2 3, 0 0) x vect(0 1) (x) vect(0 0) == vect(0 1) (x) vect(0 0) .
red load(0, 1, 2 3, 0 1) x vect(0 1) (x) vect(0 0) == vect(0 1) (x) vect(0 0) .
red load(0, 1, 2 3, 1 0) x vect(0 1) (x) vect(0 0) == vect(0 1) (x) vect(0 0) .
red load(0, 1, 2 3, 1 1) x vect(0 1) (x) vect(0 0) == vect(0 1) (x) vect(0 0) .

red load(0, 1, 2 3, 0 0) x vect(1 0) (x) vect(0 0) == vect(1 0) (x) vect(0 0) .
