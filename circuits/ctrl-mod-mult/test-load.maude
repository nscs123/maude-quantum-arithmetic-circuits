red load(0, 1, 2 3, 0 0) x vect(1 1) (x) vect(0 0) == vect(1 1) (x) vect(0 0) .
red load(0, 1, 2 3, 0 1) x vect(1 1) (x) vect(0 0) == vect(1 1) (x) vect(0 1) .
red load(0, 1, 2 3, 1 0) x vect(1 1) (x) vect(0 0) == vect(1 1) (x) vect(1 0) .
red load(0, 1, 2 3, 1 1) x vect(1 1) (x) vect(0 0) == vect(1 1) (x) vect(1 1) .

red load-unload(2, 0 0) x vect(0 0) (x) vect(0 0) == vect(0 0) (x) vect(0 0) .
red load-unload(2, 0 1) x vect(0 0) (x) vect(0 0) == vect(0 0) (x) vect(0 0) .
red load-unload(2, 1 0) x vect(0 0) (x) vect(0 0) == vect(0 0) (x) vect(0 0) .
red load-unload(2, 1 1) x vect(0 0) (x) vect(0 0) == vect(0 0) (x) vect(0 0) .

red load-unload(2, 0 0) x vect(0 1) (x) vect(0 0) == vect(0 1) (x) vect(0 0) .
red load-unload(2, 0 1) x vect(0 1) (x) vect(0 0) == vect(0 1) (x) vect(0 0) .
